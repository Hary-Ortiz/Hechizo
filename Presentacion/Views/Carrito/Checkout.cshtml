@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card-hechizo p-5">

                <h1 class="hero-title mb-3"
                    style="font-size:3rem;">
                    Finalizar Compra
                </h1>

                <p class="hero-description mb-5">
                    Completa los datos de pago para continuar
                    con tu experiencia mágica.
                </p>

                <form asp-action="ProcesarPago" method="post">

                    <div class="mb-4">
                        <label class="form-label">
                            Nombre del titular
                        </label>

                        <input type="text"
                               name="nombre"
                               class="form-control hechizo-input"
                               required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Número de tarjeta
                        </label>

                        <input type="text"
                               name="tarjeta"
                               class="form-control hechizo-input"
                               maxlength="16"
                               placeholder="1234 5678 9012 3456"
                               required />
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Fecha
                            </label>

                            <input type="text"
                                   name="fecha"
                                   class="form-control hechizo-input"
                                   placeholder="MM/AA"
                                   required />

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                CVV
                            </label>

                            <input type="password"
                                   name="cvv"
                                   maxlength="3"
                                   class="form-control hechizo-input"
                                   required />

                        </div>

                    </div>

                    <button type="submit"
                            class="btn-hechizo w-100 mt-3">
                        Procesar Pago ✨
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>
