@model List<Presentacion.Controllers.CarritoItem>


<h2 class="mb-4">Tu Carrito</h2>

@if (TempData["mensaje"] != null)
{
    <div class="alert alert-success mt-3">
        @TempData["mensaje"]
    </div>
}

@if (!Model.Any())
{
    <p>Tu carrito está vacío.</p>
}
else
{
    decimal total = 0;

    <table class="table">
        <thead>
            <tr>
                <th></th>
                <th>Producto</th>
                <th>Precio</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                total += item.precio;

                <tr>
                    <td>
                        <img src="~/img/@item.imagen"
                             style="width:80px;border-radius:8px;" />
                    </td>

                    <td>@item.nombre</td>

                    <td>$@item.precio</td>

                    <td>
                        <a asp-controller="Carrito"
                           asp-action="Eliminar"
                           asp-route-id="@item.productoId"
                           class="btn btn-danger btn-sm">
                            Quitar
                        </a>
                    </td>
                </tr>
            }

        </tbody>
    </table>

    <div class="text-end mt-4">

        <h4>Total: $@total</h4>

        <a asp-controller="Carrito"
           asp-action="Pagar"
           class="btn btn-success btn-lg mt-2">
            Pagar
        </a>

    </div>
}