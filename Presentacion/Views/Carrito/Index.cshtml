@{
    ViewData["BreadCrumb"] = "Carrito";
}
@model List<Presentacion.Controllers.CarritoItem>

<section class="page-hechizo container">

    <h1 class="title-hechizo">Tu Carrito</h1>

    <p class="subtitle-hechizo">
        Tus productos mágicos seleccionados ✨
    </p>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success mb-4">
            @TempData["mensaje"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="form-hechizo text-center">
            <h3>Tu carrito está vacío 🛒</h3>
        </div>
    }
    else
    {
        decimal total = 0;

        <div class="table-responsive">

            <table class="table table-hechizo">

                <thead>
                    <tr>
                        <th></th>
                        <th>Producto</th>
                        <th>Precio</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        total += item.precio;

                        <tr>

                            <td>
                                <img src="~/img/@item.imagen"
                                     style="width:90px;height:90px;object-fit:cover;border-radius:16px;" />
                            </td>

                            <td>@item.nombre</td>

                            <td class="price-hechizo">
                                $@item.precio
                            </td>

                            <td>
                                <a asp-controller="Carrito"
                                       asp-action="Eliminar"
                                       asp-route-id="@item.productoId"
                                       class="btn btn-danger-hechizo">

                                    Quitar
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <div class="text-end mt-5">

            <h2 class="price-hechizo mb-4">
                Total: $@total
            </h2>

            <a asp-controller="Carrito"
                   asp-action="Pagar"
                   class="btn-hechizo">

                Proceder al pago ✨
            </a>

        </div>
    }

</section>