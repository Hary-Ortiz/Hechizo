@{
    ViewData["BreadCrumb"] = "Pedidos";
}
@model IEnumerable<Hechizo.Core.Entidades.Pedido>

<section class="page-hechizo container">

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1 class="title-hechizo">Pedidos</h1>

            <p class="subtitle-hechizo">
                Órdenes realizadas dentro del sistema mágico
            </p>

        </div>

        <a asp-action="Create" class="btn-hechizo">
            Nuevo Pedido ✨
        </a>

    </div>

    <div class="table-responsive">

        <table class="table table-hechizo">

            <thead>

                <tr>
                    <th>Id Pedido</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            #@item.Id
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</section>