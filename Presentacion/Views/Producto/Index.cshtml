@{
    ViewData["BreadCrumb"] = "Menú";
}
@model IEnumerable<Hechizo.Core.Entidades.Producto>

<section class="page-hechizo container">

    <h1 class="title-hechizo">Nuestro Menú</h1>

    <p class="subtitle-hechizo">
        Café, postres y bebidas encantadas
    </p>

    <div class="row">

        @foreach (var producto in Model)
        {
            <div class="col-lg-4 col-md-6 mb-5">

                <div class="card-hechizo">

                    <img src="~/img/@producto.Imagen" />

                    <div class="card-content d-flex flex-column">

                        <h4>@producto.Nombre</h4>

                        <p>
                            @producto.Descripcion
                        </p>

                        <div class="mt-4">

                            <div class="price-hechizo mb-3">
                                $@producto.Precio
                            </div>

                            <a asp-controller="Producto"
                                   asp-action="AgregarCarrito"
                                   asp-route-id="@producto.Id"
                                   class="btn-hechizo w-100">

                                Agregar al carrito 🛒
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</section>