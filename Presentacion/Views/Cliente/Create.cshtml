<section class="page-hechizo container">

    <h1 class="title-hechizo">
        Nueva Categoría
    </h1>

    <div class="form-hechizo">

        <form asp-action="Create" method="post">

            <div class="mb-4">

                <label>Id</label>

                <input name="id" class="form-control" />

            </div>

            <div class="mb-4">

                <label>Nombre</label>

                <input name="nombre" class="form-control" />

            </div>

            <div class="mb-4">

                <label>Descripción</label>

                <input name="descripcion" class="form-control" />

            </div>

            <button type="submit" class="btn-hechizo">
                Guardar ✨
            </button>

        </form>

    </div>

</section>