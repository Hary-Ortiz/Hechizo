@model IEnumerable<Hechizo.Core.Entidades.Cliente>

<section class="page-hechizo container">

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>
            <h1 class="title-hechizo">Clientes</h1>

            <p class="subtitle-hechizo">
                Personas que forman parte de la experiencia Hechizo
            </p>
        </div>

        <a asp-action="Create" class="btn-hechizo">
            Nuevo Cliente ✨
        </a>

    </div>

    <div class="table-responsive">

        <table class="table table-hechizo">

            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>@item.Nombre</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</section>