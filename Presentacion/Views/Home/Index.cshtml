<!-- HERO -->

<section class="hero">

    <div class="hero-overlay">

        <div class="hero-grid">

            <div class="hero-left">

                <p class="hero-stars">.✦ ݁˖</p>

                <h1 class="hero-title">
                    Hechizo
                </h1>

                <h3 class="hero-subtitle">
                    Cafetería temática
                </h3>

                <p class="hero-description">
                    Café artesanal, dulces mágicos y momentos inolvidables.
                </p>

                <div class="hero-buttons">

                    <a asp-controller="Producto"
                           asp-action="Index"
                           class="btn-hechizo">
                        Ver nuestro menú
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>


<!-- CARDS -->

<section class="container cards-section">

    <div class="row g-4">

        <!-- Café especial -->
        <div class="col-md-4">

            <div class="card-hechizo">

                <img src="~/img/cafe-especial.jpg"
                     alt="Café especial" />

                <div class="card-content">

                    <h4>Café especial</h4>

                    <p>
                        Seleccionamos granos premium preparados por baristas.
                    </p>

                </div>

            </div>

        </div>


        <!-- Ambiente único -->
        <div class="col-md-4">

            <div class="card-hechizo">

                <img src="~/img/cafe-ambiente.jpg"
                     alt="Ambiente único" />

                <div class="card-content">

                    <h4>Ambiente único</h4>

                    <p>
                        Un espacio místico para disfrutar y relajarte.
                    </p>

                </div>

            </div>

        </div>


        <!-- Postres mágicos -->
        <div class="col-md-4">

            <div class="card-hechizo">

                <img src="~/img/postres-magicos.jpg"
                     alt="Postres mágicos" />

                <div class="card-content">

                    <h4>Postres mágicos</h4>

                    <p>
                        Recetas artesanales inspiradas en lo esotérico.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>