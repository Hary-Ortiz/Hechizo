<!--
    Este es un archivo de vista Razor para la acción "Index" del controlador "Categoria". 
    Muestra una lista de categorías con su imagen, nombre, descripción y un enlace para ver los productos asociados a cada categoría.
-->
@model IEnumerable<Dominio.Entidades.Categoria>

<h2 class="mb-4">Categorías</h2>

<div class="row">

@foreach (var categoria in Model)
{
    <div class="col-md-4 mb-4">

        <div class="card shadow-sm h-100">

            <img src="~/img/@categoria.Imagen"
                 class="card-img-top"
                 style="height:220px; object-fit:cover;" />

            <div class="card-body text-center">

                <h5 class="card-title">@categoria.Nombre</h5>

                <p class="text-muted">
                    @categoria.Descripcion
                </p>

                <a asp-controller="Producto"
                   asp-action="PorCategoria"
                   asp-route-categoria="@categoria.Nombre"
                   class="btn btn-hechizo">

                   Ver productos
                </a>

            </div>

        </div>

    </div>
}

</div>