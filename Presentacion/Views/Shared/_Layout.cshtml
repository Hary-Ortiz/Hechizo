<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hechizo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentacion.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
                <div class="container">

                    <!-- Logo / Título -->
                    <a class="navbar-brand fw-bold" style="color:#6f4e37;"
                       asp-controller="Home" asp-action="Index">
                        Hechizo
                    </a>

                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarContent">

                        <!-- Pestañas -->
                        <ul class="navbar-nav me-auto">

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Categoria"
                                   asp-action="Index">
                                    Categorías
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Producto"
                                   asp-action="Index">
                                    Productos
                                </a>
                            </li>

                      

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Reserva"
                                   asp-action="Index">
                                    Reservas
                                </a>
                            </li>

                        </ul>
                        </ul>

                        <!-- Barra búsqueda -->
                        <form class="d-flex me-3">
                            <input class="form-control me-2"
                                   type="search"
                                   placeholder="Buscar café..." />
                            <button class="btn"
                                    style="background-color:#6f4e37;color:white;"
                                    type="submit">
                                Buscar
                            </button>
                        </form>

                        <!-- Carrito -->
                        <a asp-controller="Carrito"
                           asp-action="Index"
                           class="btn btn-outline-dark">
                            🛒
                        </a>

                    </div>
                </div>
            </nav>
</nav>
            
                
               
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Presentacion - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
