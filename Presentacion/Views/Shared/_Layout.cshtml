<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hechizo</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hechizo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentacion.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-hechizo fixed-top">

            <div class="container-fluid px-5">

                <!-- LOGO -->
                <a class="navbar-brand logo-hechizo" asp-controller="Home" asp-action="Index">
                    HECHIZO
                </a>

                <!-- BOTÓN MOBILE -->
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarHechizo">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- LINKS -->
                <div class="collapse navbar-collapse" id="navbarHechizo">

                    <ul class="navbar-nav mx-auto gap-3">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Producto" asp-action="Index">
                                Menú
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reserva" asp-action="Index">
                                Reservas
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categoria" asp-action="Index">
                                Experiencias
                            </a>
                        </li>

                    </ul>

                    <!-- DERECHA -->
                    <div class="d-flex align-items-center gap-3">

                        <!-- BOTÓN RESERVAR -->
                        <a asp-controller="Reserva"
                               asp-action="Create"
                               class="btn btn-reserva">

                            Reservar
                        </a>

                        <!-- CARRITO -->
                        <a asp-controller="Carrito"
                               asp-action="Index"
                               class="cart-icon">

                            🛒
                        </a>

                    </div>

                </div>

            </div>

        </nav>
            
                
               
    </header>
    
    <main role="main">

        <div class="accessibility-panel">

            <button id="increaseFont"
                    class="access-btn"
                    title="Aumentar texto">

                A+

            </button>

            <button id="decreaseFont"
                    class="access-btn"
                    title="Disminuir texto">

                A-

            </button>

            <button id="toggleContrast"
                    class="access-btn"
                    title="Modo alto contraste">

                ✦

            </button>

        </div>

        @if (ViewData["Breadcrumb"] != null)
        {
            <div class="container">

                <nav aria-label="breadcrumb"
                     class="breadcrumb-hechizo">

                    <ol class="breadcrumb">

                        <li class="breadcrumb-item">

                            <a asp-controller="Home"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                        <li class="breadcrumb-item active"
                            aria-current="page">

                            @ViewData["Breadcrumb"]

                        </li>

                    </ol>

                </nav>

            </div>
        }

        @RenderBody()

    </main>
    

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Presentacion - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>

            let currentZoom = 100;

            // AUMENTAR ZOOM
            document.getElementById("increaseFont")
                .addEventListener("click", function () {

                    currentZoom += 10;

                    document.body.style.zoom =
                        currentZoom + "%";
                });

            // DISMINUIR ZOOM
            document.getElementById("decreaseFont")
                .addEventListener("click", function () {

                    currentZoom -= 10;

                    if (currentZoom < 70) {
                        currentZoom = 70;
                    }

                    document.body.style.zoom =
                        currentZoom + "%";
                });

            // CONTRASTE MÁGICO
            document.getElementById("toggleContrast")
                .addEventListener("click", function () {

                    document.body.classList
                        .toggle("magic-contrast");
                });

    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
